{
  "name": "agent88",
  "version": "1.1.0",
  "description": "Agent88 is an open source AI infrastructure framework designed to help developers build production-ready AI agents with ease.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vcky4/agent88.git"
  },
  "keywords": [],
  "author": "Victor Okon",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/Vcky4/agent88/issues"
  },
  "homepage": "https://github.com/Vcky4/agent88#readme",
  "devDependencies": {
    "@types/ioredis": "^4.28.10",
    "@types/node": "^25.3.3",
    "dotenv": "^17.3.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "ioredis": "^5.10.0",
    "openai": "^6.25.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    },
    "openai": {
      "optional": true
